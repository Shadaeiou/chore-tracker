<!-- Monochrome white sock silhouette for the status-bar notification icon.
     Android masks notification icons to a single tint, so anything
     non-white (or with gradients) renders as a flat white blob — keep
     this as a pure outline. Mirrors the in-app ic_sock geometry. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24"
    android:tint="?attr/colorControlNormal">
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M7,3 H15 V13 H20 V21 H7 Z"/>
</vector>
